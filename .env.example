# ==================== 数据源配置 ====================

# Tushare 数据接口 Token（可选，用于 A 股/基金数据）
# 申请地址: https://tushare.pro/register
TUSHARE_TOKEN=

# FRED API Key（用于美国宏观数据：TIPS 实际利率、通胀预期等）
# 申请地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ==================== 模拟交易配置 ====================

# 启用模拟交易（false 则所有模式不可用）
GOLD_CTP_ENABLED=true

# --- 模式① SimNow（上期技术官方仿真） ---
# 注册地址: https://www.simnow.com.cn
# 前置地址（SimNow 7×24 环境，不用改）
GOLD_SIMNOW_MD_ADDRESS=tcp://182.254.243.31:40011
GOLD_SIMNOW_TD_ADDRESS=tcp://182.254.243.31:40001
GOLD_SIMNOW_USER_ID=your_simnow_userid
GOLD_SIMNOW_PASSWORD=your_simnow_password



# --- 模式② openctp TTS（开放平台仿真，推荐） ---
# 注册方式: 关注微信公众号 "openctp"，自动获取账号和密码
# 前置地址（openctp TTS 7×24 环境，不用改）
GOLD_OPENCTP_MD_ADDRESS=tcp://trading.openctp.cn:30011
GOLD_OPENCTP_TD_ADDRESS=tcp://trading.openctp.cn:30001
GOLD_OPENCTP_USER_ID=openctp给的账号
GOLD_OPENCTP_PASSWORD=openctp给的密码
