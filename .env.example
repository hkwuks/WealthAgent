# ==================== 数据源配置 ====================

# Tushare 数据接口 Token（可选，用于 A 股/基金数据）
# 申请地址: https://tushare.pro/register
TUSHARE_TOKEN=

# FRED API Key（用于美国宏观数据：TIPS 实际利率、通胀预期等）
# 申请地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ==================== CTP/SimNow 模拟交易配置 ====================

# 启用 CTP 连接（true/false）
GOLD_CTP_ENABLED=true

# SimNow 账号（注册地址: https://www.simnow.com.cn）
GOLD_CTP_USER_ID=your_simnow_userid
GOLD_CTP_PASSWORD=your_simnow_password

# CTP 前置地址（7×24 环境，非交易时段可用）
GOLD_CTP_MD_ADDRESS=tcp://182.254.243.31:40011
GOLD_CTP_TD_ADDRESS=tcp://182.254.243.31:40001

# 交易时段环境（交易日 9:00-15:00 可用）
# GOLD_CTP_MD_ADDRESS=tcp://182.254.243.31:30011
# GOLD_CTP_TD_ADDRESS=tcp://182.254.243.31:30001

